# Supabase — get these from your project's Settings → API.
# The URL and anon key are public (safe to expose in the browser); RLS protects data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only. Bypasses RLS — never expose to the client. Used for admin/moderation tasks.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
